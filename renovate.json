{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "kubernetes": {
    "managerFilePatterns": [
      "/apps/.+\\.yaml$/",
      "/infrastructure/.+\\.yaml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/infrastructure/.+\\.yaml$/"
    ]
  },
  "argocd": {
    "managerFilePatterns": [
      "/clusters/.+\\.yaml$/",
      "/infrastructure/.+\\.yaml$/"
    ]
  }
}
