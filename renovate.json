{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "kubernetes": {
    "fileMatch": ["apps/.+\\.yaml$", "infrastructure/.+\\.yaml$"]
  },
  "helm-values": {
    "fileMatch": ["infrastructure/.+\\.yaml$"]
  },
  "argocd": {
    "fileMatch": ["clusters/.+\\.yaml$", "infrastructure/.+\\.yaml$"]
  }
}
